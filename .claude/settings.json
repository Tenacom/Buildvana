{
 "enabledMcpjsonServers": [
    "github"
  ],
  "enableAllProjectMcpServers": true,
  "permissions": {
    "allow": [
      "WebFetch",
      "WebSearch",
      "Bash(dotnet:*)",
      "Bash(gh run *)",
      "Bash(gh api *)",
      "Bash(gh pr *)",
      "Bash(git:*)",
      "Bash(xargs grep *)",
      "Bash(xargs head *)",
      "Bash(xargs -I {} find *)",
      "Read",
      "Glob",
      "Grep"
    ]
  }
}
